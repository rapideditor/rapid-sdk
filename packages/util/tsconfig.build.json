{
  "extends": "./tsconfig.json",
  "include": ["src/index.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "listEmittedFiles": true,
    "rootDir": "./src",
    "outDir": "./dist"
  }
}
